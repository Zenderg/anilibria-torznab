API_KEY=replace-with-a-long-random-value
PORT=8080
IMAGE=ghcr.io/zenderg/anilibria-torznab:v1.0.0

# Optional runtime overrides. Leave commented to use application defaults.
# LISTEN_ADDR=:8080
# CONTAINER_PORT=8080
# ANILIBRIA_API_BASE_URL=https://api.anilibria.app/api/v1/
# ANILIBRIA_SITE_BASE_URL=https://aniliberty.top/
# REQUEST_TIMEOUT=90s
# HTTP_TIMEOUT=15s
# REQUEST_INTERVAL=2.1s
# MAX_CONCURRENCY=4
# MAX_RELEASES_PER_SEARCH=10
# MAX_RESPONSE_BYTES=8MiB
# SEARCH_CACHE_TTL=10m
# TORRENTS_CACHE_TTL=15m
# LATEST_CACHE_TTL=5m
# NEGATIVE_CACHE_TTL=1m
# CACHE_MAX_ENTRIES=1024
# LOG_LEVEL=info
